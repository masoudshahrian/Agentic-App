# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Database (runtime data, should not be committed)
data/*.db
data/*.sqlite3

# Generated daily report files (runtime output, should not be committed)
reports/*.txt
reports/*.pdf

# Logs
*.log
server.log

# Local secrets / overrides (do NOT commit real Telegram tokens, prices, etc.)
config/settings.local.json
.env

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Packaging
*.egg-info/
build/
dist/
